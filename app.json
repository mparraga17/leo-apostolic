{
  "expo": {
    "name": "Leo Look Up",
    "slug": "leo-apostolic",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#161B33"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.leoapostolic.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.leoapostolic.app"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "beda1414-5153-4c86-b0a1-213ddbb4db3e"
      }
    },
    "owner": "pizcodeploy",
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#C9A55A"
        }
      ],
      "expo-localization",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-5368247261960193~1059510385",
          "androidAppId": "ca-app-pub-5368247261960193~8712666900",
          "userTrackingPermission": "Para ofrecerte anuncios más relevantes y mantener la app gratuita, esta app puede usar tu identificador de publicidad. Tú decides."
        }
      ],
      "expo-tracking-transparency"
    ]
  }
}
